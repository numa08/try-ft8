{
  "name": "ft8-demo-on-web",
  "version": "1.0.0",
  "description": "ブラウザだけで動く FT8 名刺交換デモ(スマホのマイク・スピーカーで交信)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "tunnel": "bash scripts/serve-tunnel.sh",
    "demo": "pnpm build && bash scripts/serve-tunnel.sh",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "deploy:cf": "vite build && wrangler deploy"
  },
  "keywords": [],
  "author": "numa08 (JK1TUT)",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
